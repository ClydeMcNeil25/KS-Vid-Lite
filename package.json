{
  "name": "ks-vid-lite",
  "version": "1.0.0-beta",
  "description": "KS-Vid-Lite is an AI-assisted desktop video editing tool designed to help creators quickly turn raw video clips into polished, social media-ready content.",
  "main": "electron/main.js",
  "scripts": {
    "dev:desktop": "electron .",
    "clean:frontend-temp": "rimraf --glob \"frontend/vite.config.js.timestamp-*.mjs\"",
    "clean:dist": "rimraf dist release frontend/dist backend/dist",
    "clean:logs": "rimraf --glob \"*.log\" \"npm-debug.log*\" \"yarn-debug.log*\" \"yarn-error.log*\"",
    "clean:all": "npm run clean:frontend-temp && npm run clean:logs",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "prepack:desktop": "npm run clean:all && npm run build:frontend && npm run build:backend",
    "build:desktop": "npm run prepack:desktop && electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClydeMcNeil25/KS-Vid-Lite.git"
  },
  "keywords": [
    "video-editor",
    "electron",
    "ffmpeg",
    "ai-assisted-editing"
  ],
  "author": "Krucial Studios",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ClydeMcNeil25/KS-Vid-Lite/issues"
  },
  "homepage": "https://github.com/ClydeMcNeil25/KS-Vid-Lite#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.1.1",
    "uuid": "^14.0.0",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "rimraf": "^5.0.5"
  },
  "build": {
    "appId": "com.krucialstudios.ksvidlite",
    "productName": "KS-Vid-Lite",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/ffprobe-static/**/*"
    ],
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/node_modules/.cache/**/*",
      "!**/test-assets/output/**/*",
      "!**/*.log",
      "!frontend/vite.config.js.timestamp-*.mjs"
    ],
    "extraResources": [
      {
        "from": "electron/assets",
        "to": "assets"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "bin/ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "bin/ffprobe.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KS-Vid-Lite"
    }
  }
}
